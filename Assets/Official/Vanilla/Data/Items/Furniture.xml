    <Define GameObjectTarget = "Thing">
        <Id>wood_table</Id>
        <label>Wood Table</label>
        <description>A simple wood table</description>
        <destroyable>true</destroyable>
        <maxStackCount>5</maxStackCount>
        <volume>12</volume>
        <mass>8</mass>
        <length>1.5</length>
        <compsProps>
            <li Class="Buildable_CompProperties">
                <rotatable>true</rotatable>
                <uninstallable>true</uninstallable>
                <repairable>true</repairable>
                <size>2, 1</size>
            </li>
            <li Class="Placeable_CompProperties">
                <requiresFoundation>false</requiresFoundation>
                <snapToGrid>true</snapToGrid>
                <placementRange>3</placementRange>
                <canRotate>true</canRotate>
                <destroyOnRemove>true</destroyOnRemove>
            </li>
        </compsProps>
    </Define>
    
